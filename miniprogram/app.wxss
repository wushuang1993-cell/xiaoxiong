page {
  min-height: 100vh;
  background: #f8f2e8;
  color: #3c2b26;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 30rpx;
}

.screen {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 32rpx 30rpx 56rpx;
}

.soft-card {
  background: rgba(255, 253, 248, 0.92);
  border-radius: 32rpx;
  box-shadow: 0 18rpx 48rpx rgba(103, 73, 50, 0.08);
}

.muted {
  color: #94877d;
  font-size: 26rpx;
}

.button {
  display: flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  height: 84rpx;
  margin: 0;
  padding: 0 28rpx;
  border-radius: 999rpx;
  border: 0;
  background: #d99a49;
  color: #fff;
  font-size: 29rpx;
  font-weight: 600;
  line-height: 1;
}

.button::after {
  border: 0;
}

.button.secondary {
  background: #82b58a;
}

.button.ghost {
  background: #f1e7d8;
  color: #7c6759;
}

.bear-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 28rpx;
  background: #fff;
  object-fit: contain;
}
