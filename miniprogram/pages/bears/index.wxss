.bears-screen {
  padding-top: 26rpx;
}

.hero {
  position: relative;
  display: flex;
  min-height: 236rpx;
  justify-content: space-between;
  align-items: center;
  overflow: hidden;
  padding: 34rpx 32rpx;
  background: linear-gradient(120deg, #fff2c9 0%, #edf7dc 100%);
}

.hero-copy {
  position: relative;
  z-index: 2;
  max-width: 360rpx;
}

.title {
  margin-top: 14rpx;
  font-size: 46rpx;
  font-weight: 800;
  line-height: 1.15;
  letter-spacing: 0;
}

.chip {
  display: inline-flex;
  margin-top: 18rpx;
  padding: 10rpx 22rpx;
  border-radius: 999rpx;
  background: rgba(214, 154, 73, 0.18);
  color: #7a5834;
  font-size: 23rpx;
  line-height: 1;
}

.hero-art {
  position: absolute;
  right: 18rpx;
  bottom: 10rpx;
  width: 210rpx;
  height: 190rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.hero-art::before {
  content: "";
  position: absolute;
  width: 170rpx;
  height: 170rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.42);
}

.hero-bear {
  position: relative;
  z-index: 1;
  width: 198rpx;
  height: 166rpx;
}

.wish-button {
  position: absolute;
  right: 26rpx;
  top: 24rpx;
  z-index: 3;
  width: 58rpx;
  height: 58rpx;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.68);
  color: #d58f9f;
  font-size: 32rpx;
  line-height: 58rpx;
}

.wish-button::after {
  border: 0;
}

.wish-strip {
  display: flex;
  justify-content: space-between;
  margin-top: 18rpx;
  padding: 18rpx 22rpx;
  background: #fffaf1;
}

.wish-item {
  display: flex;
  gap: 10rpx;
  color: #7b6a60;
  font-size: 22rpx;
}

.people-grid {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.person-card {
  flex: 1;
  min-width: 0;
  min-height: 286rpx;
  box-sizing: border-box;
  padding: 22rpx 18rpx;
  border-radius: 30rpx;
}

.person-card.pink {
  background: #f8dbe8;
}

.person-card.green {
  background: #e3f0dc;
}

.person-head {
  display: flex;
  align-items: center;
  gap: 14rpx;
}

.avatar-box {
  flex: 0 0 auto;
  width: 76rpx;
  height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  overflow: hidden;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.56);
}

.person-avatar {
  width: 66rpx;
  height: 66rpx;
}

.name {
  display: block;
  color: #6d5147;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.coin {
  display: block;
  margin-top: 6rpx;
  color: #8b7c73;
  font-size: 21rpx;
  line-height: 1.2;
}

.bear-row {
  display: flex;
  justify-content: center;
  gap: 8rpx;
  min-height: 120rpx;
  margin-top: 22rpx;
}

.mini-bear {
  width: 74rpx;
  min-height: 110rpx;
  box-sizing: border-box;
  padding: 8rpx 4rpx 10rpx;
  border-radius: 20rpx;
  background: rgba(255, 255, 255, 0.72);
  text-align: center;
  color: #5b4942;
  font-size: 18rpx;
  line-height: 1.2;
}

.mini-bear-art {
  width: 60rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 8rpx;
}

.mini-bear-art image {
  width: 58rpx;
  height: 52rpx;
}

.empty-bear {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  min-height: 88rpx;
  border-radius: 22rpx;
  background: rgba(255, 255, 255, 0.42);
  color: #9b8b82;
  font-size: 22rpx;
}

.draw-button {
  margin-top: 24rpx;
}

.action-row {
  display: flex;
  gap: 18rpx;
  margin-top: 24rpx;
}

.action-row .button {
  flex: 1;
  min-width: 0;
}

.audit {
  margin-top: 24rpx;
  padding: 24rpx 26rpx;
  background: #f3ebdc;
  box-shadow: none;
}

.audit-line {
  margin-top: 13rpx;
  color: #72645b;
  font-size: 22rpx;
  line-height: 1.45;
}

.empty {
  margin-top: 12rpx;
}
