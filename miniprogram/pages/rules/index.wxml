<view class="screen rules-screen">
  <view class="head">
    <text class="muted">家庭设置</text>
    <view class="title">规则</view>
  </view>

  <view class="soft-card section">
    <view wx:if="{{!isLoggedIn}}" class="login-form">
      <text class="section-title">邮箱登录</text>
      <view class="login-input-row">
        <input class="input login-input" placeholder="请输入邮箱" value="{{loginEmail}}" bindinput="onEmailInput" />
        <button class="login-button" bindtap="submitLogin">登录</button>
      </view>
      <text class="section-note">请输入绑定邮箱后点击登录</text>
    </view>

    <view wx:else class="login-panel logged-in">
      <view class="login-profile">
        <image class="login-avatar" src="{{loginAvatar}}" mode="aspectFit" />
      </view>
      <view class="login-detail">
        <view class="login-name-row">
          <text class="section-title">{{currentUser}}</text>
          <text class="login-badge">已登录</text>
        </view>
        <text class="section-note">{{loginEmailText}}</text>
      </view>
      <button class="switch-account" bindtap="logout">切换账号</button>
    </view>
  </view>

  <view class="soft-card section rules-card">
    <view class="section-top">
      <view>
        <text class="section-title">金币规则</text>
      </view>
      <button class="small-button edit-toggle" bindtap="toggleRulesEditing">{{rulesEditing ? '完成' : '编辑'}}</button>
    </view>

    <view wx:if="{{rulesEditing}}" class="rule-editor">
      <picker mode="selector" range="{{ruleGroups}}" range-key="label" value="{{editingRuleGroupIndex}}" bindchange="onRuleGroupChange">
        <view class="picker-field">{{selectedRuleGroupLabel}}</view>
      </picker>
      <input class="input" placeholder="规则名称，例如 买菜" value="{{ruleName}}" bindinput="onRuleNameInput" />
      <input class="input" type="text" placeholder="金币，例如 1 或 -1" value="{{ruleAmount}}" bindinput="onRuleAmountInput" />
      <button class="button" bindtap="addRule">新增规则</button>
    </view>

    <view class="rule-section" wx:for="{{ruleSections}}" wx:key="key">
      <text class="rule-section-title">{{item.title}}</text>
      <view class="rule-line" wx:for="{{item.rules}}" wx:for-item="rule" wx:key="label">
        <text class="rule-name">{{rule.label}}</text>
        <view class="rule-actions">
          <text class="rule-value {{rule.tone}}">{{rule.value}}</text>
          <view wx:if="{{rulesEditing}}" class="delete-link" data-group="{{item.key}}" data-label="{{rule.label}}" bindtap="deleteRule">×</view>
        </view>
      </view>
    </view>
  </view>

  <view class="soft-card section">
    <view class="section-top">
      <view>
        <text class="section-title">小熊目录</text>
        <text class="section-note">开启的小熊会参与抽签，最多 6 只。</text>
      </view>
    </view>
    <view class="bear-editor">
      <input class="input" placeholder="新增小熊名称" value="{{bearName}}" bindinput="onBearNameInput" />
      <button class="button secondary" bindtap="addBear">新增小熊</button>
    </view>
    <view class="bear-line" wx:for="{{state.bears}}" wx:key="name">
      <view class="bear-name">
        <image src="{{item.image}}" mode="aspectFit" />
        <text>{{item.name}}</text>
      </view>
      <switch checked="{{item.active}}" data-name="{{item.name}}" bindchange="toggleBear" color="#82b58a" />
    </view>
  </view>
</view>
