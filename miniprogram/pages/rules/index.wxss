.head {
  margin-bottom: 22rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section-top {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 18rpx;
}

.login-form {
  display: block;
}

.login-input-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  margin-top: 14rpx;
}

.login-input-row .input {
  margin-top: 0;
}

.login-input {
  flex: 1;
  min-width: 0;
}

.login-button,
.switch-account {
  flex: 0 0 132rpx;
  width: 132rpx;
  height: 78rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
  background: #d99a49;
  color: #fff;
  font-size: 27rpx;
  font-weight: 600;
  line-height: 78rpx;
}

.login-button::after,
.switch-account::after {
  border: 0;
}

.login-panel {
  display: flex;
  align-items: flex-start;
  gap: 18rpx;
}

.login-panel.logged-in {
  align-items: flex-start;
}

.login-profile {
  width: 76rpx;
  flex: 0 0 76rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.login-avatar {
  width: 82rpx;
  height: 82rpx;
  border-radius: 50%;
  background: #fff7ea;
}

.login-detail {
  flex: 1;
  min-width: 0;
}

.login-name-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.login-badge {
  padding: 6rpx 14rpx;
  border-radius: 999rpx;
  background: #e3f0dc;
  color: #6a9d70;
  font-size: 22rpx;
  line-height: 1;
}

.switch-account {
  background: #f8f0e3;
  color: #7c6759;
  font-size: 23rpx;
}

.section-title {
  display: block;
  color: #4d3a32;
  font-size: 31rpx;
  font-weight: 700;
  line-height: 1.25;
}

.section-note {
  display: block;
  margin-top: 8rpx;
  color: #9a8c81;
  font-size: 24rpx;
  line-height: 1.35;
}

.input {
  box-sizing: border-box;
  width: 100%;
  min-height: 78rpx;
  margin-top: 14rpx;
  padding: 0 22rpx;
  border-radius: 20rpx;
  background: #f8f0e3;
  color: #4d3a32;
  font-size: 27rpx;
}

.two-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.two-actions .button {
  flex: 1;
  min-width: 0;
  font-size: 24rpx;
}

.small-button {
  flex: 0 0 auto;
  min-width: 168rpx;
  height: 56rpx;
  margin: 0;
  padding: 0 18rpx;
  border-radius: 999rpx;
  background: #ffe6b9;
  color: #8a6130;
  font-size: 24rpx;
  line-height: 56rpx;
}

.small-button::after,
.delete-link::after {
  border: 0;
}

.rule-editor {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.picker-field {
  box-sizing: border-box;
  min-height: 78rpx;
  padding: 23rpx 22rpx;
  border-radius: 20rpx;
  background: #edf7f1;
  color: #5c7161;
  font-size: 27rpx;
}

.rule-section {
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid rgba(120, 98, 80, 0.08);
}

.rule-section-title {
  display: block;
  color: #9a7651;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.2;
}

.rule-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
  padding: 13rpx 0;
  color: #5b4942;
}

.rule-name {
  color: #5b4942;
  font-size: 26rpx;
  line-height: 1.25;
}

.rule-actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 0 0 auto;
}

.rule-value {
  font-size: 24rpx;
}

.plus {
  color: #669e70;
}

.minus {
  color: #d26f82;
}

.delete-link {
  width: 38rpx;
  height: 38rpx;
  flex: 0 0 38rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0;
  padding: 0;
  border-radius: 50%;
  background: #fae3e7;
  color: #c76578;
  font-size: 24rpx;
  line-height: 1;
}

.bear-editor {
  display: flex;
  gap: 14rpx;
  align-items: center;
}

.bear-editor .input {
  flex: 1;
  min-width: 0;
}

.bear-editor .button {
  flex: 0 0 180rpx;
  height: 78rpx;
  font-size: 27rpx;
}

.bear-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(120, 98, 80, 0.1);
}

.bear-name {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: #5b4942;
  font-size: 27rpx;
}

.bear-name image {
  width: 58rpx;
  height: 58rpx;
  border-radius: 18rpx;
  background: #fff9ef;
}
