.head {
  margin-bottom: 22rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section-title {
  display: block;
  margin-bottom: 8rpx;
  font-size: 28rpx;
  font-weight: 700;
}

.rule-line {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(120, 98, 80, 0.1);
  font-size: 24rpx;
}

.plus {
  color: #669e70;
}

.minus {
  color: #d26f82;
}

.note {
  margin-top: 22rpx;
  padding: 24rpx;
  color: #8d7f73;
  font-size: 22rpx;
}
