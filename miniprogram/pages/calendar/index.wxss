.head {
  margin-bottom: 22rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.person-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.person-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: #fffaf1;
  font-size: 25rpx;
}

.person-pill.active {
  background: #ffe6b9;
}

.person-pill image {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
}

.calendar-card {
  margin-top: 22rpx;
  padding: 24rpx 22rpx;
}

.calendar-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.month-title {
  color: #4d3a32;
  font-size: 31rpx;
  font-weight: 700;
}

.month-button {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f8f0e3;
  color: #9b7b58;
  font-size: 38rpx;
  line-height: 1;
}

.week-row {
  display: flex;
  color: #a3958a;
  font-size: 23rpx;
  line-height: 1;
}

.week-row text {
  width: 14.285%;
  text-align: center;
}

.month-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.day-cell {
  position: relative;
  box-sizing: border-box;
  width: 14.285%;
  height: 62rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6a554c;
  font-size: 25rpx;
}

.day-cell text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 46rpx;
  height: 46rpx;
  border-radius: 18rpx;
}

.day-cell.today text {
  background: #f7ead5;
}

.day-cell.selected text {
  background: #dfa044;
  color: #fff;
}

.empty-day {
  pointer-events: none;
}

.record-dot {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #82b58a;
}

.section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section-title {
  font-size: 31rpx;
  font-weight: 700;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.tag {
  margin: 0;
  padding: 0 22rpx;
  height: 64rpx;
  border-radius: 999rpx;
  background: #edf7f9;
  color: #5b6c70;
  font-size: 26rpx;
  line-height: 64rpx;
}

.tag.minus {
  background: #fae3e7;
  color: #c86476;
}

.log-line {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(120, 98, 80, 0.1);
  font-size: 27rpx;
}

.minus-log {
  color: #c86476;
}

.empty {
  margin-top: 20rpx;
}
