.head {
  margin-bottom: 22rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 48rpx;
  font-weight: 800;
}

.person-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.person-switch.in-records {
  margin-top: 18rpx;
}

.person-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 18rpx;
  border-radius: 28rpx;
  background: #fffaf1;
  font-size: 27rpx;
}

.person-pill-copy {
  min-width: 0;
  display: flex;
  flex-direction: column;
  line-height: 1.25;
}

.person-pill.active {
  background: #ffe6b9;
}

.person-pill image {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
}

.calendar-card {
  margin-top: 24rpx;
  padding: 28rpx 24rpx;
}

.calendar-top {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 22rpx;
}

.month-title {
  color: #4d3a32;
  font-size: 34rpx;
  font-weight: 700;
}

.month-button {
  width: 54rpx;
  height: 54rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 50%;
  background: #f8f0e3;
  color: #9b7b58;
  font-size: 38rpx;
  line-height: 1;
}

.week-row {
  display: flex;
  color: #a3958a;
  font-size: 25rpx;
  line-height: 1;
}

.week-row text {
  width: 14.285%;
  text-align: center;
}

.month-grid {
  display: flex;
  flex-wrap: wrap;
  margin-top: 18rpx;
}

.day-cell {
  position: relative;
  box-sizing: border-box;
  width: 14.285%;
  height: 68rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #6a554c;
  font-size: 27rpx;
}

.day-cell text {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  border-radius: 18rpx;
}

.day-cell.today text {
  background: #f7ead5;
}

.day-cell.selected text {
  background: #dfa044;
  color: #fff;
}

.empty-day {
  pointer-events: none;
}

.record-dot {
  position: absolute;
  bottom: 4rpx;
  width: 8rpx;
  height: 8rpx;
  border-radius: 50%;
  background: #82b58a;
}

.section {
  margin-top: 24rpx;
  padding: 28rpx;
}

.section-title {
  font-size: 34rpx;
  font-weight: 700;
}

.tag-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx 14rpx;
  margin-top: 20rpx;
  padding: 0 18rpx;
}

.tag {
  box-sizing: border-box;
  display: inline-block;
  justify-self: center;
  width: auto;
  max-width: 100%;
  min-width: 0;
  margin: 0;
  padding: 0 14rpx;
  height: 56rpx;
  border-radius: 999rpx;
  background: #edf7f9;
  color: #5b6c70;
  font-size: 23rpx;
  line-height: 56rpx;
  text-align: center;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.tag::after {
  border: 0;
}

.tag.minus {
  background: #fae3e7;
  color: #c86476;
}

.log-line {
  display: flex;
  justify-content: space-between;
  gap: 18rpx;
  padding: 10rpx 0;
  color: #72645b;
  font-size: 25rpx;
  line-height: 1.45;
}

.record-card {
  background: #f3ebdc;
  box-shadow: none;
}

.record-card .section-title {
  color: #94877d;
  font-size: 26rpx;
  font-weight: 400;
}

.record-card .log-line:first-of-type {
  margin-top: 10rpx;
}

.minus-log {
  color: #c86476;
}

.empty {
  margin-top: 20rpx;
}
