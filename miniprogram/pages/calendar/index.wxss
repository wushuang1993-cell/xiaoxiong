.head {
  margin-bottom: 22rpx;
}

.title {
  margin-top: 10rpx;
  font-size: 44rpx;
  font-weight: 800;
}

.person-switch {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 18rpx;
}

.person-pill {
  display: flex;
  align-items: center;
  gap: 12rpx;
  padding: 16rpx;
  border-radius: 28rpx;
  background: #fffaf1;
}

.person-pill.active {
  background: #ffe6b9;
}

.person-pill image {
  width: 58rpx;
  height: 58rpx;
  border-radius: 50%;
}

.section {
  margin-top: 22rpx;
  padding: 26rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 700;
}

.tag-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.tag {
  margin: 0;
  padding: 0 22rpx;
  height: 58rpx;
  border-radius: 999rpx;
  background: #edf7f9;
  color: #5b6c70;
  font-size: 24rpx;
  line-height: 58rpx;
}

.log-line {
  display: flex;
  justify-content: space-between;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(120, 98, 80, 0.1);
  font-size: 24rpx;
}

.empty {
  margin-top: 20rpx;
}
