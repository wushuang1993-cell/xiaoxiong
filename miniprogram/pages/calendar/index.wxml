<view class="screen calendar-screen">
  <view class="head">
    <text class="muted">{{dateText}}</text>
    <view class="title">家务日历</view>
  </view>

  <view class="person-switch">
    <view class="person-pill {{selectedPerson === item.name ? 'active' : ''}}" wx:for="{{state.people}}" wx:key="name" data-name="{{item.name}}" bindtap="selectPerson">
      <image src="{{item.image}}" mode="aspectFit" />
      <text>{{item.name}}</text>
      <text class="muted">{{item.coins}} 金币</text>
    </view>
  </view>

  <view class="soft-card calendar-card" bindtouchstart="onCalendarTouchStart" bindtouchend="onCalendarTouchEnd">
    <view class="calendar-top">
      <view class="month-button" bindtap="prevMonth">‹</view>
      <view class="month-title">{{calendarMonthText}}</view>
      <view class="month-button" bindtap="nextMonth">›</view>
    </view>
    <view class="week-row">
      <text wx:for="{{weekDays}}" wx:key="*this">{{item}}</text>
    </view>
    <view class="month-grid">
      <view
        class="day-cell {{item.isEmpty ? 'empty-day' : ''}} {{item.isToday ? 'today' : ''}} {{item.isSelected ? 'selected' : ''}}"
        wx:for="{{calendarDays}}"
        wx:key="key"
        data-day="{{item.day}}"
        bindtap="selectDay"
      >
        <text wx:if="{{!item.isEmpty}}">{{item.day}}</text>
        <view wx:if="{{item.hasLogs}}" class="record-dot"></view>
      </view>
    </view>
  </view>

  <view class="soft-card section">
    <text class="section-title">记录类型</text>
    <view class="tag-grid">
      <button class="tag {{item.tone}}" wx:for="{{quickRules}}" wx:key="label" data-label="{{item.label}}" data-delta="{{item.delta}}" bindtap="addLog">{{item.label}}</button>
    </view>
  </view>

  <view class="soft-card section">
    <text class="section-title">{{selectedDateTitle}}</text>
    <view class="log-line {{item.delta < 0 ? 'minus-log' : ''}}" wx:for="{{todayLogs}}" wx:key="index">
      <text>{{item.person}} · {{item.type}}</text>
      <text>{{item.delta > 0 ? '+' : ''}}{{item.delta}}</text>
    </view>
    <view wx:if="{{!todayLogs.length}}" class="muted empty">今天还没有记录</view>
  </view>
</view>
